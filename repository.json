    {
      "id": "open-library-enricher",
      "name": "Open Library Enricher",
      "overview": "Fetches book metadata, covers, and identifiers from Open Library's free API",
      "description": "Enriches book metadata from Open Library",
      "author": "Shisho Team",
      "homepage": "https://github.com/shishobooks/plugins",
      "imageUrl": "https://raw.githubusercontent.com/shishobooks/plugins/master/plugins/open-library-enricher/logo.svg",
      "versions": [
        {
          "version": "0.3.1",
          "manifestVersion": 1,
          "releaseDate": "2026-04-12",
          "changelog": "## [0.3.1] - 2026-04-12\n\n### Bug Fixes\n- Capture last commit in release changelog generation (#15)\n",
          "downloadUrl": "https://github.com/shishobooks/plugins/releases/download/open-library-enricher@0.3.1/open-library-enricher-0.3.1.zip",
          "sha256": "a57ad85cbe1b3288aa3e7f3d38a279f40f4e12aa14c6925094aec629d061cf99",
          "minShishoVersion": "0.0.23",
          "capabilities": {
            "metadataEnricher": {
              "description": "Fetches metadata from Open Library API",
              "fileTypes": [
                "epub",
                "m4b",
                "pdf"
              ],
              "fields": [
                "title",
                "subtitle",
                "authors",
                "narrators",
                "description",
                "publisher",
                "releaseDate",
                "series",
                "seriesNumber",
                "genres",
                "tags",
                "cover",
                "identifiers"
              ]
            },
            "httpAccess": {
              "description": "Calls Open Library API and fetches cover images",
              "domains": [
                "*.openlibrary.org",
                "*.archive.org"
              ]
            },
            "identifierTypes": [
              {
                "id": "openlibrary_work",
                "name": "Open Library Work",
                "urlTemplate": "https://openlibrary.org/works/{value}",
                "pattern": "^OL\\d+W$"
              },
              {
                "id": "openlibrary_edition",
                "name": "Open Library Edition",
                "urlTemplate": "https://openlibrary.org/books/{value}",
                "pattern": "^OL\\d+M$"
              }
            ]
          }
        },
