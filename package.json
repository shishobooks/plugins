{
  "name": "shisho-plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "node esbuild.config.cjs",
    "build:watch": "node esbuild.config.cjs --watch",
    "start": "MAIN_WORKTREE=$(git worktree list | head -1 | awk '{print $1}') COMPOSE_MENU=false docker compose up --pull always",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "concurrently --kill-others-on-fail --group \"pnpm:lint:*\"",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:prettier": "prettier --check .",
    "lint:types": "tsc --noEmit",
    "check": "pnpm lint && pnpm test",
    "release": "./scripts/release.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@shisho/plugin-sdk": "0.0.28",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "prettier": "3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
